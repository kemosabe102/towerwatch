# Local secrets — never commit
secrets.h
pi/secrets.py
pi/credentials.py
src/towerwatch/credentials.py
src/towerwatch/credentials.*.py
!src/towerwatch/credentials.py.example

# Python bytecode (may contain compiled secrets)
__pycache__/
*.pyc

# Test artifacts (Windows local testing)
pi/speedtest_bin/
pi/speedtest.zip
pi/data/
data/

# CI build artifact (stamped by ci.sh, not source) — new path
src/towerwatch/_version.txt

# Virtual env
.venv/
*.egg-info/

# Local deploy wrapper (contains host-specific config)
deploy-local.sh

# Claude Code local config/skills
.claude/

# CI build artifact (stamped by ci.sh, not source)
pi/version.txt
ci-tmp/

# Bench harness runtime artifacts (live on Pi at /opt/towerwatch/data/bench/)
pi/bench/reports/
pi/bench/snapshots/
pi/bench/state.json
.worktrees/

# Code-review session artifacts — kept locally as a record, never committed
# (also keeps ci.sh's clean-tree check from blocking on them)
docs/code-review-*.md

# Static curl binary for the phone-compare tool (vetted external arm64 build,
# pushed to the phone via adb — not committed). See docs/phone-compare.md.
scripts/curl-android-arm64
