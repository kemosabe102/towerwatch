{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for towerwatch metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    { "type": "grafana", "id": "grafana", "name": "Grafana", "version": "10.0.0" },
    { "type": "datasource", "id": "prometheus", "name": "Prometheus", "version": "1.0.0" },
    { "type": "panel", "id": "stat", "name": "Stat", "version": "" },
    { "type": "panel", "id": "timeseries", "name": "Time series", "version": "" }
  ],
  "annotations": { "list": [] },
  "editable": true,
  "graphTooltip": 1,
  "panels": [
    {
      "id": 1,
      "title": "Connected — $location_a",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 0 },
      "targets": [
        { "expr": "last_over_time(towerwatch_connected{host=\"$location_a\"}[5m])", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 2,
      "title": "Connected — $location_b",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 0 },
      "targets": [
        { "expr": "last_over_time(towerwatch_connected{host=\"$location_b\"}[5m])", "refId": "A" }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "DOWN", "color": "red" }, "1": { "text": "UP", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 3,
      "title": "Uptime (24h) — $location_a",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 12, "x": 0, "y": 4 },
      "targets": [
        { "expr": "avg_over_time((max_over_time(towerwatch_connected{host=\"$location_a\"}[5m]))[$__range:5m])", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 4,
      "title": "Uptime (24h) — $location_b",
      "type": "stat",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 4, "w": 12, "x": 12, "y": 4 },
      "targets": [
        { "expr": "avg_over_time((max_over_time(towerwatch_connected{host=\"$location_b\"}[5m]))[$__range:5m])", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } }
    },
    {
      "id": 5,
      "title": "RTT Avg — $location_a",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 8 },
      "targets": [
        { "expr": "towerwatch_rtt_avg_google{host=\"$location_a\"}", "legendFormat": "Google", "refId": "A" },
        { "expr": "towerwatch_rtt_avg_cloudflare{host=\"$location_a\"}", "legendFormat": "Cloudflare", "refId": "B" },
        { "expr": "towerwatch_rtt_avg_gateway{host=\"$location_a\"}", "legendFormat": "Gateway", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 } }
    },
    {
      "id": 6,
      "title": "RTT Avg — $location_b",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 8 },
      "targets": [
        { "expr": "towerwatch_rtt_avg_google{host=\"$location_b\"}", "legendFormat": "Google", "refId": "A" },
        { "expr": "towerwatch_rtt_avg_cloudflare{host=\"$location_b\"}", "legendFormat": "Cloudflare", "refId": "B" },
        { "expr": "towerwatch_rtt_avg_gateway{host=\"$location_b\"}", "legendFormat": "Gateway", "refId": "C" }
      ],
      "fieldConfig": { "defaults": { "unit": "ms", "min": 0 } }
    },
    {
      "id": 7,
      "title": "Packet Loss — $location_a",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 16 },
      "targets": [
        { "expr": "towerwatch_pkt_loss_google{host=\"$location_a\"}", "legendFormat": "Google", "refId": "A" },
        { "expr": "towerwatch_pkt_loss_cloudflare{host=\"$location_a\"}", "legendFormat": "Cloudflare", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 8,
      "title": "Packet Loss — $location_b",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 16 },
      "targets": [
        { "expr": "towerwatch_pkt_loss_google{host=\"$location_b\"}", "legendFormat": "Google", "refId": "A" },
        { "expr": "towerwatch_pkt_loss_cloudflare{host=\"$location_b\"}", "legendFormat": "Cloudflare", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "percent", "min": 0, "max": 100 } }
    },
    {
      "id": 9,
      "title": "HTTP Throughput — $location_a",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 24 },
      "targets": [
        { "expr": "towerwatch_http_throughput_mbps{host=\"$location_a\"}", "legendFormat": "Throughput", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "min": 0, "custom": { "drawStyle": "bars", "fillOpacity": 50, "pointSize": 8, "showPoints": "always" } } }
    },
    {
      "id": 10,
      "title": "HTTP Throughput — $location_b",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 24 },
      "targets": [
        { "expr": "towerwatch_http_throughput_mbps{host=\"$location_b\"}", "legendFormat": "Throughput", "refId": "A" }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "min": 0, "custom": { "drawStyle": "bars", "fillOpacity": 50, "pointSize": 8, "showPoints": "always" } } }
    },
    {
      "id": 11,
      "title": "Speedtest History — $location_a",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 32 },
      "targets": [
        { "expr": "towerwatch_speedtest_download_mbps{host=\"$location_a\"}", "legendFormat": "Down · {{triggered_by}}", "refId": "A" },
        { "expr": "towerwatch_speedtest_upload_mbps{host=\"$location_a\"}", "legendFormat": "Up · {{triggered_by}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "min": 0, "custom": { "drawStyle": "points", "pointSize": 10, "showPoints": "always", "lineWidth": 0 } } }
    },
    {
      "id": 12,
      "title": "Speedtest History — $location_b",
      "type": "timeseries",
      "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 32 },
      "targets": [
        { "expr": "towerwatch_speedtest_download_mbps{host=\"$location_b\"}", "legendFormat": "Down · {{triggered_by}}", "refId": "A" },
        { "expr": "towerwatch_speedtest_upload_mbps{host=\"$location_b\"}", "legendFormat": "Up · {{triggered_by}}", "refId": "B" }
      ],
      "fieldConfig": { "defaults": { "unit": "Mbps", "min": 0, "custom": { "drawStyle": "points", "pointSize": 10, "showPoints": "always", "lineWidth": 0 } } }
    }
  ],
  "schemaVersion": 38,
  "tags": ["towerwatch", "compare"],
  "templating": {
    "list": [
      {
        "name": "location_a",
        "label": "Location A",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(towerwatch_connected, host)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false
      },
      {
        "name": "location_b",
        "label": "Location B",
        "type": "query",
        "datasource": { "type": "prometheus", "uid": "${DS_PROMETHEUS}" },
        "query": "label_values(towerwatch_connected, host)",
        "refresh": 1,
        "sort": 1,
        "includeAll": false,
        "multi": false
      }
    ]
  },
  "time": { "from": "now-24h", "to": "now" },
  "timezone": "",
  "title": "Towerwatch — Side-by-Side Comparison",
  "uid": "",
  "version": 0,
  "refresh": "30s"
}
