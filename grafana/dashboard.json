{
  "__inputs": [
    {
      "name": "DS_PROMETHEUS",
      "label": "Prometheus",
      "description": "Prometheus datasource for towerwatch metrics",
      "type": "datasource",
      "pluginId": "prometheus",
      "pluginName": "Prometheus"
    }
  ],
  "__requires": [
    {
      "type": "grafana",
      "id": "grafana",
      "name": "Grafana",
      "version": "10.0.0"
    },
    {
      "type": "datasource",
      "id": "prometheus",
      "name": "Prometheus",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    }
  ],
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": true,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Annotations & Alerts",
        "type": "dashboard"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-towerwatch-prom"
        },
        "enable": true,
        "expr": "towerwatch_connected{host=\"towerwatch\"} == 0",
        "hide": false,
        "iconColor": "red",
        "name": "Outages",
        "titleFormat": "Connection Down"
      },
      {
        "datasource": {
          "type": "prometheus",
          "uid": "grafanacloud-towerwatch-prom"
        },
        "enable": true,
        "expr": "absent_over_time(towerwatch_connected{host=\"towerwatch\"}[10m])",
        "hide": false,
        "iconColor": "dark-purple",
        "name": "Pi Offline",
        "titleFormat": "Pi Offline (no data ≥10 min)"
      },
      {
        "datasource": {
          "type": "grafana",
          "uid": "-- Grafana --"
        },
        "enable": true,
        "hide": false,
        "iconColor": "dark-red",
        "name": "Recorded Outages",
        "target": {
          "type": "tags",
          "matchAny": false,
          "tags": ["towerwatch", "outage"]
        }
      }
    ]
  },
  "description": "5G connection quality monitoring — latency, jitter, packet loss, and uptime",
  "editable": true,
  "fiscalYearStartMonth": 0,
  "graphTooltip": 1,
  "id": null,
  "links": [],
  "panels": [
    {
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "title": "Connection Uptime",
      "description": "Percentage of time the connection was up over the selected time range",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-towerwatch-prom"
      },
      "targets": [
        {
          "expr": "clamp_max(sum_over_time(towerwatch_connected{host=\"towerwatch\"}[$__range]) / scalar(vector($__range_s / 60)) * 100, 100)",
          "legendFormat": "Uptime",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-towerwatch-prom"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "decimals": 2,
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "yellow",
                "value": 95
              },
              {
                "color": "green",
                "value": 99.5
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "gridPos": {
        "h": 4,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "title": "Current Status",
      "description": "Live connection status based on the most recent probe",
      "type": "stat",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-towerwatch-prom"
      },
      "targets": [
        {
          "expr": "last_over_time(towerwatch_connected{host=\"towerwatch\"}[5m])",
          "legendFormat": "Status",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-towerwatch-prom"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            {
              "type": "value",
              "options": {
                "0": {
                  "text": "DOWN",
                  "color": "red"
                },
                "1": {
                  "text": "UP",
                  "color": "green"
                }
              }
            }
          ],
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "red",
                "value": null
              },
              {
                "color": "green",
                "value": 1
              }
            ]
          },
          "color": {
            "mode": "thresholds"
          }
        },
        "overrides": []
      },
      "options": {
        "reduceOptions": {
          "calcs": [
            "lastNotNull"
          ],
          "fields": "",
          "values": false
        },
        "orientation": "auto",
        "textMode": "auto",
        "colorMode": "background",
        "graphMode": "none",
        "justifyMode": "auto"
      }
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 28
      },
      "id": 4,
      "title": "Packet Loss",
      "description": "Percentage of TCP probes that failed per 30-second cycle",
      "type": "timeseries",
      "datasource": {
        "type": "prometheus",
        "uid": "grafanacloud-towerwatch-prom"
      },
      "targets": [
        {
          "expr": "towerwatch_pkt_loss_google{host=\"towerwatch\"}",
          "legendFormat": "Google",
          "refId": "A",
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-towerwatch-prom"
          }
        },
        {
          "expr": "towerwatch_pkt_loss_cloudflare{host=\"towerwatch\"}",
          "legendFormat": "Cloudflare",
          "refId": "B",
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-towerwatch-prom"
          }
        },
        {
          "expr": "towerwatch_pkt_loss_gateway{host=\"towerwatch\"}",
          "legendFormat": "Gateway",
          "refId": "C",
          "datasource": {
            "type": "prometheus",
            "uid": "grafanacloud-towerwatch-prom"
          }
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "percent",
          "min": 0,
          "max": 100,
          "custom": {
            "drawStyle": "line",
            "lineInterpolation": "stepAfter",
            "lineWidth": 2,
            "fillOpacity": 0,
            "pointSize": 5,
            "showPoints": "auto",
            "spanNulls": 120000,
            "axisBorderShow": false,
            "scaleDistribution": {
              "type": "linear"
            },
            "thresholdsStyle": {
              "mode": "off"
            }
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 10
              },
              {
                "color": "orange",
                "value": 25
              },
              {
                "color": "red",
                "value": 50
              }
            ]
          },
          "color": {
            "mode": "fixed"
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Google"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#73BF69"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Cloudflare"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#F2CC0C"
                }
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Gateway"
            },
            "properties": [
              {
                "id": "color",
                "value": {
                  "mode": "fixed",
                  "fixedColor": "#FF9830"
                }
              }
            ]
          }
        ]
      },
      "options": {
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        },
        "legend": {
          "displayMode": "list",
          "placement": "bottom",
          "calcs": [
            "mean",
            "max"
          ]
        }
      }
    },
    {
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
