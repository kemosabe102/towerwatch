"""
Towerwatch credentials — copy this file to credentials.py and fill in your values.

    cp credentials.py.example credentials.py
    chmod 600 credentials.py

credentials.py is gitignored and must never be committed.
"""

# Location identifier for this deployment — becomes the `host` metric tag and
# Loki stream label. Must be stable: changing it creates discontinuities in
# dashboards. Use kebab-case, no spaces. Examples: "home", "remote-site-1".
# Each Pi gets its own credentials.py with its own LOCATION string.
LOCATION = "towerwatch"

# Grafana Cloud credentials (Prometheus — for metrics)
# Find these at: grafana.com → your stack → Access Policies or API Keys
# Generate with: echo -n 'INSTANCE_ID:API_KEY' | base64
GRAFANA_INSTANCE_ID = (
    "YOUR_PROMETHEUS_INSTANCE_ID"  # numeric, shown in the Prometheus datasource Details
)
GRAFANA_API_KEY = "YOUR_API_KEY_HERE"
# Note: GRAFANA_API_KEY is also used by the bench harness for metrics:read + logs:read queries.

# Loki credentials (DIFFERENT instance ID from Prometheus above)
# Find at: grafana.com/orgs/<your-org> → your stack → Loki → Details
# Look for "URL" under "Using Grafana with Logs" — it ends in .grafana.net
# Append /loki/api/v1/push to that URL
LOKI_URL = "https://logs-prod-XXX.grafana.net/loki/api/v1/push"
LOKI_USER = "YOUR_LOKI_NUMERIC_INSTANCE_ID"  # a number — NOT the Prometheus instance ID above
LOKI_TOKEN = "YOUR_API_TOKEN"  # same token works for both Prometheus and Loki

# Cellular router admin password (e.g. Netgear M6 admin login)
M6_ADMIN_PASSWORD = "YOUR_ROUTER_ADMIN_PASSWORD"

# Grafana Cloud service account token with "annotations:read" + "annotations:write" permission.
# Also used by the bench harness (pi/bench/) to READ annotations when verifying outage tests.
# Used to POST sticky region annotations when an outage ≥10 min is detected.
# Create at: grafana.com → your stack → Administration → Service accounts → New
#   role: Editor (or custom with annotations:write), then "Add service account token".
# Leave blank to disable outage annotations (metrics/logs still work).
GRAFANA_ANNOTATION_TOKEN = ""
