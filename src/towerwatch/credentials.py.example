"""
Towerwatch credentials — copy this file to credentials.py and fill in your values.

    cp credentials.py.example credentials.py
    chmod 600 credentials.py

credentials.py is gitignored and must never be committed.
"""

# Location identifier for this deployment — becomes the `host` metric tag and
# Loki stream label. Must be stable: changing it creates discontinuities in
# dashboards. Use kebab-case, no spaces. Examples: "home", "remote-site-1".
# Each Pi gets its own credentials.py with its own LOCATION string.
LOCATION = "towerwatch"

# --- Per-site connection context ---
# These become Prometheus labels (carrier, connection_type) baked into every
# metric line and Loki stream. They also drive probe selection — e.g. the M6
# cellular probe self-disables when CONNECTION_TYPE is not cellular, so the
# probe doesn't waste HTTP attempts against a non-Netgear gateway.
#
# CARRIER: lowercase slug. Examples: "verizon", "tmobile", "att", "comcast",
#          "spectrum", "ziply", "centurylink", "other".
CARRIER = "other"
#
# CONNECTION_TYPE: lowercase slug. Examples: "fiber", "cable", "dsl",
#                  "5g_cellular", "lte_cellular", "fixed_wireless", "satellite".
CONNECTION_TYPE = "other"
#
# EXPERIMENT_LABEL: optional A/B-test tag baked onto every metric as a
# Prometheus label, so `avg by (experiment) (...)` compares a run against
# baseline in one query (e.g. antenna position). Lowercase/underscore; spaces
# are slugged. Leave as None ("none") normally; set it for the duration of an
# experiment, then RESET to None and redeploy so distinct values don't pile up
# against the free-tier series cap. Changing it takes effect on the next deploy
# (restart), which cleanly marks the experiment boundary in the data.
EXPERIMENT_LABEL = None
#
# EXPECTED_DOWNLINK_MBPS / EXPECTED_UPLINK_MBPS: rough plan capacity in Mbps.
# Used by the Saturation Golden Signal (current throughput as % of plan) and
# to pick a reasonable gauge max per site. Set to None to skip — Saturation
# tile will then read 0% and gauges fall back to compile-time defaults.
EXPECTED_DOWNLINK_MBPS = None
EXPECTED_UPLINK_MBPS = None
#
# HTTP_THROUGHPUT_BYTES_OVERRIDE / HTTP_UPLOAD_BYTES_OVERRIDE: per-site sizing
# for the HTTP throughput / upload probes. Default None uses the config.py
# values (5 MB down / 2 MB up — sized for 200 Mbps cellular). On fast links
# (≥500 Mbps) bump these so each sample lasts long enough (~400 ms) to clear
# TCP slow-start; otherwise throughput readings are systematically biased low.
# Suggested starting points: 1 Gbps → 50_000_000 / 10_000_000.
# Mind the data-budget invariant in CLAUDE.md before bumping on metered links.
HTTP_THROUGHPUT_BYTES_OVERRIDE = None
HTTP_UPLOAD_BYTES_OVERRIDE = None
#
# GATEWAY_IP_OVERRIDE: pin the gateway IP instead of relying on default-route
# auto-discovery. Useful when the M6 lives at a non-default IP (e.g. 10.0.1.1)
# or when the Pi's default route is otherwise misleading. Leave as None for
# auto-discovery.
GATEWAY_IP_OVERRIDE = None
#
# --- Cloudflare adaptive throughput probe — per-site cadence ---
# Cloudflare's adaptive ramp sizes individual transfers to the measured speed,
# so byte-cap tuning is rarely needed. The lever you usually want is just how
# often the probe runs. Defaults: 2/day with no time-window pinning.
#
# CLOUDFLARE_THROUGHPUT_TESTS_PER_DAY_OVERRIDE: integer number of runs per day.
# Common values: 1 for high-bandwidth home links where variation is uninteresting,
# 3 paired with WINDOWS for diurnal sampling on cellular sites. Leave None to
# use the config.py default.
CLOUDFLARE_THROUGHPUT_TESTS_PER_DAY_OVERRIDE = None
#
# CLOUDFLARE_THROUGHPUT_WINDOWS_OVERRIDE: list of (start_hour, end_hour) tuples
# in 24-hour local time, end exclusive. When set, the scheduler picks one
# random time within each window per day instead of dividing the day into
# equal slots. Length must equal TESTS_PER_DAY when both are set. Useful for
# pinning samples to morning/midday/evening on cellular links where carrier
# behavior varies by time of day.
# Example: [(6, 10), (11, 14), (17, 21)] paired with TESTS_PER_DAY=3.
CLOUDFLARE_THROUGHPUT_WINDOWS_OVERRIDE = None
#
# CLOUDFLARE_THROUGHPUT_MAX_TOTAL_BYTES_OVERRIDE / CLOUDFLARE_UPLOAD_MAX_TOTAL_BYTES_OVERRIDE:
# escape hatch for metered links if Cloudflare's adaptive ramp is consuming
# more data than the carrier's plan tolerates. You normally don't need to
# touch these — the cadence override above is the primary lever.
CLOUDFLARE_THROUGHPUT_MAX_TOTAL_BYTES_OVERRIDE = None
CLOUDFLARE_UPLOAD_MAX_TOTAL_BYTES_OVERRIDE = None

# Grafana Cloud credentials (Prometheus — for metrics)
# Find these at: grafana.com → your stack → Access Policies or API Keys
# Generate with: echo -n 'INSTANCE_ID:API_KEY' | base64
GRAFANA_INSTANCE_ID = (
    "YOUR_PROMETHEUS_INSTANCE_ID"  # numeric, shown in the Prometheus datasource Details
)
GRAFANA_API_KEY = "YOUR_API_KEY_HERE"
# Note: GRAFANA_API_KEY is also used by the bench harness for metrics:read + logs:read queries.

# Loki credentials (DIFFERENT instance ID from Prometheus above)
# Find at: grafana.com/orgs/<your-org> → your stack → Loki → Details
# Look for "URL" under "Using Grafana with Logs" — it ends in .grafana.net
# Append /loki/api/v1/push to that URL
LOKI_URL = "https://logs-prod-XXX.grafana.net/loki/api/v1/push"
LOKI_USER = "YOUR_LOKI_NUMERIC_INSTANCE_ID"  # a number — NOT the Prometheus instance ID above
LOKI_TOKEN = "YOUR_API_TOKEN"  # same token works for both Prometheus and Loki

# Cellular router admin password (e.g. Netgear M6 admin login)
M6_ADMIN_PASSWORD = "YOUR_ROUTER_ADMIN_PASSWORD"

# Grafana Cloud service account token with "annotations:read" + "annotations:write" permission.
# Also used by the bench harness (pi/bench/) to READ annotations when verifying outage tests.
# Used to POST sticky region annotations when an outage ≥10 min is detected.
# Create at: grafana.com → your stack → Administration → Service accounts → New
#   role: Editor (or custom with annotations:write), then "Add service account token".
# Leave blank to disable outage annotations (metrics/logs still work).
GRAFANA_ANNOTATION_TOKEN = ""
